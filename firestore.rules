rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email is string ? request.auth.token.email : null;
    }

    function isUserDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function emailMatchesResource() {
      return userEmail() != null && resource.data.email == userEmail();
    }

    // User profile docs
    match /users/{userId} {
      allow read, create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Orders are created/updated on the server only (Firebase Admin SDK).
    // Client can only read own docs by uid or email.
    match /orders/{orderId} {
      allow read: if isSignedIn() && (isUserDocOwner() || emailMatchesResource());
      allow create, update, delete: if false;
    }

    // Bookings are created/updated on the server only (Firebase Admin SDK).
    // Client can only read own docs by uid or email.
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isUserDocOwner() || emailMatchesResource());
      allow create, update, delete: if false;
    }

    // Public catalog visibility (active only). Writes are server-side only.
    match /books/{bookId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    match /courses/{courseId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    // Internal collections: server-side only.
    match /messages/{messageId} {
      allow read, write: if false;
    }

    match /protected_access_logs/{logId} {
      allow read, write: if false;
    }

    match /protected_active_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
