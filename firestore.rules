rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email is string ? request.auth.token.email : null;
    }

    function isUserDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isUserRequestOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function emailMatchesResource() {
      return userEmail() != null && resource.data.email == userEmail();
    }

    function emailMatchesRequest() {
      return userEmail() != null && request.resource.data.email == userEmail();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (isUserDocOwner() || emailMatchesResource());
      allow create: if isSignedIn() && (isUserRequestOwner() || emailMatchesRequest());
      allow update, delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isUserDocOwner() || emailMatchesResource());
      allow create: if request.resource.data.status == "pending";
      allow update, delete: if false;
    }

    match /books/{bookId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    match /courses/{courseId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    match /messages/{messageId} {
      allow read, write: if false;
    }
  }
}

