rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPublished() {
      return resource.data.status == 'published';
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'user';
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /courses/{courseId} {
      allow read: if isPublished() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /course_lessons/{lessonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if isPublished() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && (request.resource.data.status == 'pending' || request.resource.data.status == 'payment_submitted');
      allow update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && (request.resource.data.status == 'pending' || request.resource.data.status == 'payment_submitted');
      allow update, delete: if isAdmin();
    }

    match /course_progress/{progressId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }


    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'published' || isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /protected_content/{contentId} {
      allow read, write: if isAdmin();
    }


    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }


    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /availability_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payment_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /seo_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notification_templates/{docId} {
      allow read, write: if isAdmin();
    }

    match /navigation_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /media_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ai_guide_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /feature_flags/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /integration_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /policy_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /security_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /operations_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /email_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /calendar_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /experiment_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /pricing_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /backup_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /legal_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /academy_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /journeys/{journeyId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /bundles/{bundleId} {
      allow read: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /drive_assets/{assetId} {
      allow read, write: if isAdmin();
    }

    match /admin_homepage_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_customer_journey_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_theme_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_content_ops_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_quality_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_automation_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_commerce_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_assessment_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_analytics_events_settings/{docId} {
      allow read, write: if isAdmin();
    }


    match /{document=**} {
      allow read, write: if false;
    }
  }
}
